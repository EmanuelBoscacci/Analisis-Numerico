@model WebApplicationAnalisisNumerico.Models.RootFindingInput
@{
    ViewData["Title"] = "Buscador de Raíces";
    var result = ViewData["Result"] as WebApplicationAnalisisNumerico.Models.RootFindingResult;
}

<h2>Buscador de Raíces - Métodos Abiertos y Cerrados</h2>
<form asp-action="Index" method="post" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>

    <div class="col-md-6">
        <label class="form-label">Función (usar 'x' como variable, ejemplo: x^3 - 2*x - 5)</label>
        <input asp-for="Function" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Método</label>
        <select asp-for="Method" class="form-select" id="Method">
            <option>Secante</option>
            <option>Tangente</option>
            <option>Biseccion</option>
            <option>ReglaFalsa</option>
        </select>
    </div>
    <div class="col-md-3">
        <label class="form-label">Xi</label>
        <input asp-for="Xi" class="form-control" />
    </div>
    <div class="col-md-3" id="xdField">
        <label class="form-label">Xd (solo Secante y métodos cerrados)</label>
        <input asp-for="Xd" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Tolerancia</label>
        <input asp-for="Tolerance" class="form-control" />
    </div>
    <div class="col-md-3">
        <label class="form-label">Máx Iteraciones</label>
        <input asp-for="MaxIterations" class="form-control" />
    </div>
    <div class="col-12">
        <button type="submit" class="btn btn-primary">Calcular</button>
    </div>
</form>

@if (result != null)
{
    <h3>Resultado</h3>
    <div class="mb-3">
        @if (!string.IsNullOrEmpty(result.Message))
        {
            var alertClass = result.Converged ? "alert alert-success" : "alert alert-warning";
            <div class="@alertClass" role="alert">@result.Message</div>
        }
        <p><strong>Convergió:</strong> @result.Converged</p>
        <p><strong>Raíz:</strong> @result.Root</p>
    </div>

    <h4>Gráfico (GeoGebra)</h4>
    <div id="ggb-element" style="width:100%;max-width:820px;height:480px;" class="my-3 border rounded"></div>

    <h4 class="mt-4">Iteraciones</h4>
    <table class="table table-striped">
        <thead>
            <tr>
                <th>#</th>
                <th>Xi</th>
                <th>Xd</th>
                <th>Xr</th>
                <th>f(Xr)</th>
                <th>Error</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var it in result.Iterations)
            {
                <tr>
                    <td>@it.Iteration</td>
                    <td>@it.Xi</td>
                    <td>@it.Xd</td>
                    <td>@it.Xr</td>
                    <td>@it.Fx</td>
                    <td>@it.Error</td>
                </tr>
            }
        </tbody>
    </table>
}

<partial name="_ValidationScriptsPartial" />

@section Scripts {
    <script>
        (function(){
            function toggleXd() {
                var method = document.getElementById('Method').value;
                var xdField = document.getElementById('xdField');
                if (method === 'Secante' || method === 'Biseccion' || method === 'ReglaFalsa') {
                    xdField.style.display = 'block';
                } else {
                    xdField.style.display = 'none';
                }
            }
            var sel = document.getElementById('Method');
            if (sel) {
                sel.addEventListener('change', toggleXd);
                toggleXd();
            }
        })();
    </script>

    @if (result != null)
    {
        <script src="https://www.geogebra.org/apps/deployggb.js"></script>
        <script>
            (function () {
                var funcStr = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(Model.Function ?? ""));
                var rootVal = @result.Root.ToString("G", System.Globalization.CultureInfo.InvariantCulture);
                var iterations = @Html.Raw(System.Text.Json.JsonSerializer.Serialize(result.Iterations));

                var ggbParams = {
                    "appName": "graphing",
                    "width": 820,
                    "height": 480,
                    "showToolBar": false,
                    "showMenuBar": false,
                    "showAlgebraInput": false,
                    "showResetIcon": true,
                    "enableShiftDragZoom": true,
                    "enableRightClick": false,
                    "appletOnLoad": function (api) {
                        // Plot the function (funcStr is JSON-serialized, so special chars are escaped)
                        api.evalCommand("f(x) = " + funcStr);

                        // Mark iteration Xr points on the curve (blue)
                        iterations.forEach(function (it, i) {
                            var label = "It" + (i + 1);
                            api.evalCommand(label + " = (" + it.Xr + ", f(" + it.Xr + "))");
                            api.setPointStyle(label, 0);
                            api.setPointSize(label, 5);
                            api.setColor(label, 13, 110, 253);
                            api.setLabelVisible(label, false);
                        });

                        // Mark the found root on the x-axis (red, larger)
                        if (isFinite(rootVal)) {
                            api.evalCommand("Raiz = (" + rootVal + ", 0)");
                            api.setPointStyle("Raiz", 0);
                            api.setPointSize("Raiz", 8);
                            api.setColor("Raiz", 220, 53, 69);
                            api.setLabelVisible("Raiz", true);
                            api.setLabelStyle("Raiz", 3);
                        }
                    }
                };

                var ggbApp = new GGBApplet(ggbParams, true);
                window.addEventListener("load", function () {
                    ggbApp.inject("ggb-element");
                });
            })();
        </script>
    }
}
