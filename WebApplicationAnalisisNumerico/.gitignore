# Ignorar archivos de build, IDEs y temporales
# Ajustá según tus necesidades

# VS / Visual Studio
.vs/
*.user
*.suo
*.userosscache
*.sln.docstates

# Build outputs
bin/
obj/
publish/

# Rider
.idea/

# VSCode
.vscode/

# NuGet
*.nupkg
# packages folder (if present - not used by SDK-style projects)
packages/

# Dotnet user secrets
secrets.json

# Logs
*.log

# Test results
TestResults/

# Runtime files
*.pid
*.seed

# OS generated files
.DS_Store
Thumbs.db

# Node/npm
node_modules/
npm-debug.log*

# JetBrains Rider caches
.idea/
*.sln.iml

# Optional: si no querés subir DLLs locales (por ejemplo Calculus.dll), descomenta la línea siguiente
# libs/*.dll

# OneDrive / temp folders
*.tmp
*.temp

# Certificate / publish profile
*.pfx

# Coverage
coverage/

# Misc
*.vsix

# End of .gitignore
